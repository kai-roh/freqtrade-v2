# Binance API (Futures Trading 권한만, Withdraw OFF)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-opus-4-7
# 소프트 캡: 도달 시 폴백 모델로 자동 강등
CLAUDE_MODEL_FALLBACK=claude-haiku-4-5-20251001
CLAUDE_DAILY_COST_USD_MAX=10.0
# 하드 캡: 도달 시 호출 자체 차단 (0.0/hold 반환)
CLAUDE_DAILY_COST_HARD_STOP=20.0
# 감성 캐시 TTL (초). 기본 30분
CLAUDE_CACHE_TTL_SECONDS=1800

# === 뉴스 컨텍스트 (LLM 입력용) ===
# 프로바이더: none | cryptopanic
LLM_NEWS_PROVIDER=none
# CryptoPanic 무료 API 토큰 (https://cryptopanic.com/developers/api/)
CRYPTOPANIC_TOKEN=
# 뉴스 fetch 캐시 TTL (초). 기본 5분 — rate limit 보호용
LLM_NEWS_CACHE_TTL_SECONDS=300

# Freqtrade Web UI
FREQTRADE_USERNAME=kai
FREQTRADE_PASSWORD=change_this_strong_password
JWT_SECRET=run_openssl_rand_hex_32_and_paste_here

# 텔레그램 알림 (선택, 안 쓸 거면 비워둠)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# 운영 모드 플래그 (수동 제어용)
KAI_MODE=normal
